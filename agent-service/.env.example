# LLM provider opcional.
# Default seguro: deterministic-safe, sem chamada externa.
# Nunca commite uma chave real.
AUTOSEGURO_LLM_PROVIDER=disabled
AUTOSEGURO_LLM_MODE=auto
AUTOSEGURO_LLM_TIMEOUT_SECONDS=8
AUTOSEGURO_LLM_MAX_RETRIES=1
AUTOSEGURO_LLM_REAL_SMOKE_ENABLED=false

# OpenAI direto.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Azure OpenAI.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_MINI=

# OpenAI-compatible / Azure Foundry.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_DEPLOYMENT=
AZURE_FOUNDRY_API_VERSION=

# API legada de cotacao.
QUOTE_API_URL=http://localhost:8000
QUOTE_TIMEOUT_SECONDS=3
QUOTE_MAX_ATTEMPTS=3
QUOTE_CIRCUIT_FAILURE_THRESHOLD=3
QUOTE_CIRCUIT_COOLDOWN_SECONDS=10
QUOTE_CACHE_TTL_SECONDS=900
QUOTE_CACHE_STALE_IF_ERROR_SECONDS=86400

# Logs auditaveis com PII mascarada.
FLIGHT_RECORDER_PATH=runtime/logs/conversations.jsonl

# Persistencia local opcional. Default recomendado para o take-home: memory.
AUTOSEGURO_STATE_STORE=memory
AUTOSEGURO_SQLITE_PATH=runtime/state/autoseguro.db
